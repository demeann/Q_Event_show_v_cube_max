# =====================================================================
# Мессенджер MAX (Platform API)
# =====================================================================
# Кабинет: business.max.ru → Чат-боты → Интеграция → токен.
# В HTTP-запросах: заголовок Authorization: <MAX_ACCESS_TOKEN>
#
MESSENGER_PLATFORM=max
MAX_ACCESS_TOKEN=вымкфмаым

# Для MESSENGER_PLATFORM=max не обязателен. Нужен только для MESSENGER_PLATFORM=telegram.
BOT_TOKEN=

# =====================================================================
# Database (MySQL 8)
# =====================================================================
# Для `alembic upgrade head` достаточно этого блока (токен бота не нужен).
#
# --- Локально в Docker (см. README / docker-compose) ---
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_NAME=qclub_dev
# DB_USER=qclub
# DB_PASSWORD=qclub_dev
#
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=qclub_dev
DB_USER=qclub
DB_PASSWORD=qclub_dev

# =====================================================================
# Игра
# =====================================================================
# Дата начала Дня 1 Тура 1 в зоне МСК, формат YYYY-MM-DD.
GAME_START_DATE_MSK=2026-05-15

# Разрешённые домены email через запятую.
ALLOWED_EMAIL_DOMAINS=pmru.com,contracted.pmru.com

# Ограничение входа: только пользователи, открывшие бота с параметром start=<токен>
# (ссылка приглашения в MAX — по шаблону из кабинета / документации).
# INVITE_ONLY=true
# INVITE_START_TOKENS=token_one,token_two

# =====================================================================
# Админы
# =====================================================================
# user_id в MAX (в БД колонка по-прежнему telegram_user_id — в неё пишется id MAX).
ADMIN_IDS=

# =====================================================================
# Логи
# =====================================================================
LOG_LEVEL=INFO
LOG_DIR=logs

# =====================================================================
# Запуск
# =====================================================================
# Для MAX сейчас поддержан только polling (long poll GET /updates).
# RUN_MODE=webhook — пока только для инстанса Telegram.
RUN_MODE=polling

# Ниже — поля для Telegram webhook (для MAX можно не задавать).
WEBHOOK_BASE_URL=
WEBHOOK_PATH=/qclub/webhook
# WEBHOOK_SECRET=
WEBHOOK_LISTEN_HOST=127.0.0.1
WEBHOOK_LISTEN_PORT=8081
